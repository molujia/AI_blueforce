{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "status_query_request.schema.json",
  "title": "StatusQueryRequest",
  "type": "object",
  "required": ["request_id", "session_id", "task_id"],
  "properties": {
    "request_id": {"type": "string"},
    "session_id": {"type": "string"},
    "task_id": {"type": "string"},
    "query_fields": {
      "type": "array",
      "items": {"enum": ["task_status", "actor_position", "distance_to_goal", "active_bt", "active_node", "last_return_code", "progress_rate", "blocked_reason"]}
    }
  },
  "additionalProperties": false
}

